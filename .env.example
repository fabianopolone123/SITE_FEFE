# Copie este arquivo para .env e preencha os valores reais.
# Nunca suba o .env para o git.

# Gere com: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria

# False em produção, True apenas para desenvolvimento local
DEBUG=False

# IP ou domínio do servidor, separados por vírgula. Ex: 192.168.1.10,meusite.com.br
ALLOWED_HOSTS=localhost,127.0.0.1

# Caminho do Chrome/Chromium no servidor (deixe vazio para detecção automática)
# Exemplo Linux: /usr/bin/google-chrome-stable
# Exemplo Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_PATH=

# Subpath de deploy — preencha se o site rodar em /mapa (não em raiz)
DJANGO_SCRIPT_NAME=/mapa
